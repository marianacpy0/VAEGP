import omni.usd
import time
from pxr import UsdGeom, UsdPhysics, Gf, Usd, PhysxSchema, Sdf

stage = omni.usd.get_context().get_stage()

# Limpia todo cable anterior
paths_to_delete = []
for prim in stage.Traverse():
    if "cable" in prim.GetPath().pathString.lower():
        paths_to_delete.append(prim.GetPath())
for p in reversed(paths_to_delete):
    if stage.GetPrimAtPath(p).IsValid():
        stage.RemovePrim(Sdf.Path(p))
time.sleep(0.5)

# Saca posición Y orientación del tubo dinámicamente
tube_prim = stage.GetPrimAtPath("/World/tn_817089_IT_ASSY_61MM1/tn_IQ817035_61MM_INSERTION_TUBE_THI")
xf = UsdGeom.Xformable(tube_prim)
world_transform = xf.ComputeLocalToWorldTransform(Usd.TimeCode.Default())

tip_pos = world_transform.ExtractTranslation()
rotation = world_transform.ExtractRotationMatrix()
tube_axis = Gf.Vec3d(
    rotation.GetColumn(2)[0],
    rotation.GetColumn(2)[1],
    rotation.GetColumn(2)[2]
).GetNormalized()

print(f"tip_pos: {tip_pos}")
print(f"tube_axis: {tube_axis}")

base = "/World/cable_root"
UsdGeom.Xform.Define(stage, base)

# Physics scene
scene_path = "/World/PhysicsScene"
if stage.GetPrimAtPath(scene_path).IsValid():
    stage.RemovePrim(Sdf.Path(scene_path))
scene = UsdPhysics.Scene.Define(stage, scene_path)
scene.CreateGravityDirectionAttr(Gf.Vec3f(0, 0, -1))
scene.CreateGravityMagnitudeAttr(1.5)

# Parámetros
num_segs = 15
radio = 0.002
largo = 0.015
prev_path = None

