import omni.usd
from pxr import UsdGeom, Gf, UsdPhysics
import math, time

stage = omni.usd.get_context().get_stage()

# Crear cilindro delgado (el "probe")
cylinder_path = "/World/probe_tip"
cylinder = UsdGeom.Cylinder.Define(stage, cylinder_path)
cylinder.GetRadiusAttr().Set(0.3)
cylinder.GetHeightAttr().Set(8.0)
cylinder.GetAxisAttr().Set("Y")

# Posicionarlo donde sale el cable del borescope
xform = UsdGeom.Xformable(cylinder)
xform.ClearXformOpOrder()
translate_op = xform.AddTranslateOp()
translate_op.Set(Gf.Vec3d(-8, 0, 2))
rotate_op = xform.AddRotateXYZOp()

print("Probe created! Starting 4-DOF motion...")

# Movimiento 4 DOF
for i in range(200):
    t = i * 0.05
    x = 30 * math.sin(t)
    y = 20 * math.sin(t * 0.7)
    rotate_op.Set(Gf.Vec3f(x, y, 0))
    time.sleep(0.03)







