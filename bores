import omni.usd
from pxr import UsdGeom, Gf
import math, time

stage = omni.usd.get_context().get_stage()

# Buscar el prim automáticamente
target = None
for prim in stage.Traverse():
    if "817035" in prim.GetName():
        target = prim
        print("Found:", prim.GetPath())
        break

if target:
    xform = UsdGeom.Xformable(target)
    xform.ClearXformOpOrder()
    rotate_op = xform.AddRotateXYZOp()
    for i in range(100):
        angle = 30 * math.sin(i * 0.1)
        rotate_op.Set(Gf.Vec3f(angle, 0, 0))
        time.sleep(0.05)
else:
    print("Not found")







