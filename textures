    draw.line([(210, 180), (240, 210)], fill=(20, 20, 20), width=2)
    draw.line([(195, 250), (165, 280)], fill=(20, 20, 20), width=2)
    
    save_path = r"C:\Users\castma~1\AppData\Local\Temp\crack_texture.png"
    img.save(save_path)
