xf = UsdGeom.Xformable(tube_prim)
tip_pos = xf.ComputeLocalToWorldTransform(Usd.TimeCode.Default()).ExtractTranslation()

segment_height = 0.01
num_segments = 15

# Crea segmentos con RigidBody
for i in range(num_segments):
    path = f"/World/cable_segment_{i}"
    prims_utils.create_prim(
        prim_path=path,
        prim_type="Cylinder",
        position=[tip_pos[0], tip_pos[1], tip_pos[2] + (i * segment_height)],
        scale=[0.002, 0.002, 0.008]
    )
    prim = stage.GetPrimAtPath(path)
    
