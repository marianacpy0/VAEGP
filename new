stage = omni.usd.get_context().get_stage()

# Borra anteriores
for i in range(15):
    path = f"/World/cable_segment_{i}"
    if stage.GetPrimAtPath(path).IsValid():
        omni.kit.commands.execute("DeletePrims", paths=[path])
for i in range(14):
    path = f"/World/cable_joint_{i}"
    if stage.GetPrimAtPath(path).IsValid():
        omni.kit.commands.execute("DeletePrims", paths=[path])

# Saca posición del tubo
