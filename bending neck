    auto_attachment = PhysxSchema.PhysxAutoAttachmentAPI.Apply(attachment.GetPrim())
    auto_attachment.CreateEnableDeformableVertexAttachmentsAttr(True)
    auto_attachment.CreateDeformableVertexOverlapOffsetAttr(0.01)  # tune to cable radius

    return attachment.GetPrim()


def build_bending_neck():
    stage = get_stage()

    tip_point, direction = find_cable_tip(stage, CABLE_PRIM_PATH)
    print(f"Cable tip located at: {tip_point}, axis direction: {direction}")

    segment_paths = []
