    Why not a bounding box: a bounding-box "longest dimension" guess only
    works for a straight rod. Once the cable bends, its box gets wider in
    the bend directions too, so the box can pick the wrong axis or land on
    a point in the middle instead of the actual tip -- which is exactly
    the "floating dot, not near the cable" bug from before.

    Fix: read the cable's actual simulated mesh points (world space), and
    take whichever point is FARTHEST from the known fixed anchor (the
    kinematic Cube on the other end). That's robust to any amount of
    bending or curvature, because it's based on real point positions
    instead of a geometric guess about shape.
    """
    cable_prim = stage.GetPrimAtPath(cable_path)
    anchor_prim = stage.GetPrimAtPath(anchor_path)
    if not cable_prim.IsValid():
        raise RuntimeError(f"Cable prim not found at {cable_path}")
    if not anchor_prim.IsValid():
        raise RuntimeError(f"Anchor prim not found at {anchor_path}")

    # Anchor's world position (the fixed end we're measuring distance from).
    anchor_xformable = UsdGeom.Xformable(anchor_prim)
    anchor_world_transform = anchor_xformable.ComputeLocalToWorldTransform(Usd.TimeCode.Default())
    anchor_pos = anchor_world_transform.Transform(Gf.Vec3d(0, 0, 0))

    # Cable's current mesh points, transformed into world space. Reading
    # the live "points" attribute (not a cached bounding box) is what
    # makes this reflect the CURRENT deformed/bent shape, not the rest pose
    # -- run this while the sim is in Play so points reflect the live sim,
    # same requirement as your skin-mesh generation elsewhere.
    cable_mesh = UsdGeom.Mesh(cable_prim)
    points_attr = cable_mesh.GetPointsAttr()
    local_points = points_attr.Get(Usd.TimeCode.Default())
    if not local_points or len(local_points) == 0:
        raise RuntimeError(
            f"No points found on {cable_path} -- make sure you're in Play "
            "so the deformable's simulated mesh points are populated."
        )

    # CORRECTED based on your diagnostic printout: this project's Cable
    # mesh stores points in LOCAL space (confirmed -- raw points ranged
    # -0.5 to 0.5, nowhere near the anchor's real world position of
    # ~(4.94, 4.60, 4.72)). My earlier assumption that PhysX writes
    # world-space points directly was wrong for this setup. The prim's
    # own local-to-world transform (translation ~4.67, 4.70, 4.70 plus
    # rotation/scale, as printed) is what actually places these points
    # correctly in the world -- so it needs to be applied.
    cable_xformable = UsdGeom.Xformable(cable_prim)
    cable_world_transform = cable_xformable.ComputeLocalToWorldTransform(Usd.TimeCode.Default())
    world_points = [cable_world_transform.Transform(Gf.Vec3d(p)) for p in local_points]

    farthest_point = None
    farthest_dist_sq = -1.0

    for wp in world_points:
        diff = wp - anchor_pos
        d_sq = Gf.Dot(diff, diff)
        if d_sq > farthest_dist_sq:
            farthest_dist_sq = d_sq
            farthest_point = wp

    # Direction: from the anchor toward the tip. Simple and robust -- good
    # enough to seed the first neck segment's orientation; the joint chain
    # itself is what actually controls fine bending afterward.
    direction = (farthest_point - anchor_pos).GetNormalized()

    return farthest_point, direction


