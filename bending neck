def measure_cable_world_radius(stage, cable_path, tip_point, direction, sample_window=0.01):
    """
    Measures the cable's ACTUAL world-space radius directly from its live
    mesh points, instead of trusting the "Radius" property value.

    Why this is necessary: the Cable prim's local-to-world transform
    includes a non-uniform scale (confirmed in your diagnostic printout --
    roughly 0.06 on the cross-section axes). That means the radius number
    you tune is a LOCAL value; the cable's true size in the scene is that
    number scaled down by the prim's own transform. Using the raw radius
    directly for the neck segments (like the previous version did) made
    them come out roughly 15x too big -- exactly the "why is it so much
    bigger" bug.

    Approach: take the mesh points near the tip, project each onto the
    plane perpendicular to `direction`, and use the largest distance from
    the centerline as the radius. This reflects the cable's REAL current
    size regardless of what any property panel says.
    """
    cable_prim = stage.GetPrimAtPath(cable_path)
    cable_mesh = UsdGeom.Mesh(cable_prim)
    local_points = cable_mesh.GetPointsAttr().Get(Usd.TimeCode.Default())

    cable_xformable = UsdGeom.Xformable(cable_prim)
    cable_world_transform = cable_xformable.ComputeLocalToWorldTransform(Usd.TimeCode.Default())
    world_points = [cable_world_transform.Transform(Gf.Vec3d(p)) for p in local_points]

    direction = Gf.Vec3d(direction).GetNormalized()

    max_radius = 0.0
    for wp in world_points:
        to_point = wp - tip_point
        # Only consider points near the tip (within sample_window along
        # the length direction), so we're measuring the tip's cross
        # section, not some other part of the cable.
        along_length = Gf.Dot(to_point, direction)
        if abs(along_length) > sample_window:
            continue
        # Distance from the centerline = component of to_point
        # perpendicular to direction.
        perpendicular = to_point - direction * along_length
        dist = perpendicular.GetLength()
        if dist > max_radius:
            max_radius = dist

    if max_radius <= 0.0:
        raise RuntimeError(
            "Could not measure cable radius near the tip -- try increasing "
            "sample_window, or check that CABLE_PRIM_PATH / tip_point are correct."
        )

    return max_radius


